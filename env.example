# ════════════════════════════════════════════════════════════
#  BBVA RAG Assistant — Variables de Entorno
#  Copia este archivo como .env y completa los valores.
# ════════════════════════════════════════════════════════════

# ── LLM (requerido) ──────────────────────────────────────────
# API Key gratuita en: https://console.groq.com  (sin tarjeta)
GROQ_API_KEY=tu_api_key_aqui

# Modelo Groq a usar. Opciones:
#   llama-3.1-8b-instant     → rápido, liviano (recomendado)
#   llama-3.3-70b-versatile  → más potente, un poco más lento
LLM_MODEL=llama-3.1-8b-instant
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=512

# ── Embeddings (open source, corre local) ────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Reranker (open source, corre local) ──────────────────────
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# Cuántos docs pasan al LLM después del reranking
RERANKER_TOP_K=3
# Cuántos docs recuperar antes del reranking
RETRIEVAL_K=10

# ── Vector Store ─────────────────────────────────────────────
VECTOR_DB_TYPE=faiss
FAISS_INDEX_PATH=data/faiss_index

# ── Procesamiento ─────────────────────────────────────────────
# Tamaño de chunk en palabras
CHUNK_SIZE=500
# Fracción de overlap entre chunks (0.0 – 0.5)
CHUNK_OVERLAP_RATIO=0.1

# ── Conversación ─────────────────────────────────────────────
# Número de mensajes previos que el sistema recuerda por sesión
HISTORY_K=5
DB_PATH=data/db/chat_history.db

# ── Scraping ─────────────────────────────────────────────────
BBVA_URL=https://www.bbva.com.co/
# Máximo de páginas en modo multi-página
SCRAPE_MAX_PAGES=20
# Timeout por request (segundos)
SCRAPE_TIMEOUT=15
# Delay entre requests en modo multi-página (segundos)
SCRAPE_DELAY=1.0

# ── Rutas de datos ────────────────────────────────────────────
RAW_DATA_PATH=data/raw
CLEAN_DATA_PATH=data/clean

# ── Logging ───────────────────────────────────────────────────
# Niveles: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
